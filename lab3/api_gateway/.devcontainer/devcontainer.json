{
    "name": "API Gateway Service",
    "dockerFile": "Dockerfile",
    "containerEnv": {
        "CCACHE_DIR": "/home/ubuntu/api_gateway/.ccache",
        "CORES_DIR": "/cores",
        "PREFIX": "${PREFIX:-~/.local}",
        "SHELL": "/bin/bash"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "llvm-vs-code-extensions.vscode-clangd",
                "ms-vscode.cmake-tools",
                "ms-vscode.makefile-tools",
                "vadimcn.vscode-lldb",
                "ms-azuretools.vscode-docker"
            ],
            "settings": {
                "clangd.arguments": [
                    "--background-index",
                    "--compile-commands-dir=.vscode",
                    "--clang-tidy",
                    "--completion-style=detailed",
                    "--header-insertion=never"
                ],
                "clangd.path": "/usr/bin/clangd",
                "cmake.automaticReconfigure": false,
                "cmake.configureOnEdit": false,
                "cmake.configureOnOpen": false,
                "cmake.copyCompileCommands": "${workspaceFolder}/.vscode/compile_commands.json"
            }
        }
    },
    "forwardPorts": [ 8080 ],
    "mounts": [],
    "onCreateCommand": "sudo git config --global --add safe.directory /home/ubuntu/api_gateway",
    "runArgs": [
        "--cap-add=SYS_PTRACE",
        "--security-opt",
        "seccomp=unconfined"
    ],
    "workspaceFolder": "/home/ubuntu/api_gateway",
    "workspaceMount": "source=${localWorkspaceFolder},target=/home/ubuntu/api_gateway,type=bind"
}
